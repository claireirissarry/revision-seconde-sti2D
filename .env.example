# Supabase — récupère ces valeurs dans Project Settings > API de ton projet Supabase
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Utilisées uniquement par le script de seed (npm run seed), jamais exposées au navigateur.
# SUPABASE_SERVICE_ROLE_KEY est SECRÈTE : ne jamais la commiter ni la préfixer par VITE_.
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key
